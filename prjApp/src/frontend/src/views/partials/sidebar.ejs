<aside class="app-sidebar">
  <div class="brand">
    <span class="brand-mark">PM</span>
    <div>
      <div class="brand-title">Quản lý dự án SV</div>
      <div class="brand-sub">Jira · GitHub · Spring</div>
    </div>
  </div>

  <nav class="nav-list">
    <a class="nav-item active" data-view="dashboard">
      <span class="nav-icon">📊</span>
      <span>Tổng quan</span>
    </a>
    <a class="nav-item" data-view="projects">
      <span class="nav-icon">📁</span>
      <span>Dự án của tôi</span>
    </a>
    <% if (roleKey === 'ADMIN' || roleKey === 'GIANG_VIEN' || roleKey === 'TRUONG_NHOM') { %>
    <a class="nav-item" data-view="teams">
      <span class="nav-icon">👥</span>
      <span>Nhóm & Thành viên</span>
    </a>
    <% } %>

    <% if (roleKey === 'ADMIN') { %>
    <a class="nav-item" data-view="users">
      <span class="nav-icon">👤</span>
      <span>Quản lý tài khoản</span>
    </a>
    <% } %>

    <% if (roleKey === 'ADMIN' || roleKey === 'GIANG_VIEN') { %>
    <a class="nav-item" data-view="create-project">
      <span class="nav-icon">➕</span>
      <span>Tạo dự án mới</span>
    </a>
    <% } %>
    <a class="nav-item" data-view="tasks">
      <span class="nav-icon">✅</span>
      <span>Nhiệm vụ</span>
    </a>
    <a class="nav-item" data-view="reports">
      <span class="nav-icon">📝</span>
      <span>Báo cáo</span>
    </a>
  </nav>

  <div class="current-role-card" style="margin-top: auto;">
    <span class="current-role-label">Tài khoản</span>
    <strong id="displayUsername" class="current-role-name">Đang tải...</strong>
    <div class="badge-role" style="margin-top: 0.5rem; background: rgba(255,255,255,0.1)">
      <span class="badge-label">Vai trò</span>
      <strong style="font-size: 0.75rem;"><%= roleLabel %></strong>
    </div>
  </div>

  <div class="panel session-panel" style="padding: 0.75rem; font-size: 0.8rem;">
    <details>
      <summary style="cursor: pointer; color: var(--sidebar-muted);">Cấu hình kết nối</summary>
      <div style="margin-top: 0.5rem;" class="stack">
        <div style="display: none">
          <label class="field-label" for="backendUrl">Backend URL</label>
          <input id="backendUrl" class="input input-sm" value="<%= backendUrl %>" />
        </div>
        <label class="field-label" for="token">Mã token</label>
        <input id="token" class="input input-sm input-mono" readonly />
        
        <div class="hidden-context" style="display:none">
          <input id="ctxGroupId" />
          <input id="ctxLecturerId" />
          <input id="ctxStudentId" />
        </div>

        <div class="btn-row">
          <button type="button" id="saveSessionBtn" class="btn btn-secondary btn-sm">Lưu</button>
          <button type="button" id="logoutBtn" class="btn btn-danger btn-sm">Thoát</button>
        </div>
      </div>
    </details>
  </div>
</aside>
