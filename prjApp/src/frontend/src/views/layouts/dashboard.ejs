<% const _roleLabel = typeof roleLabel !== "undefined" ? roleLabel : "Người dùng"; %>
<% const _roleKey = typeof roleKey !== "undefined" ? roleKey : "THANH_VIEN"; %>
<!DOCTYPE html>
<html lang="vi">
<head>
  <%- include('../partials/head', { title: typeof pageTitle !== 'undefined' ? pageTitle : 'Dashboard' }) %>
</head>
<body class="app-body">
  <script>
    (function () {
      var expected = "<%= _roleKey %>";
      var key = "pm_tool_session";
      try {
        var raw = localStorage.getItem(key);
        if (!raw) {
          window.location.replace("/dang-nhap?next=" + encodeURIComponent(window.location.pathname));
          return;
        }
        var s = JSON.parse(raw);
        if (!s.token) {
          window.location.replace("/dang-nhap?next=" + encodeURIComponent(window.location.pathname));
        }
        // role check is handled later via /api/auth/me for more reliability
      } catch (e) {
        window.location.replace("/dang-nhap");
      }
    })();
  </script>

  <div class="app-shell">
    <%- include('../partials/sidebar', { roleKey: _roleKey, roleLabel: _roleLabel, backendUrl }) %>
    <div class="app-main">
      <%- include('../partials/topbar', { roleLabel: _roleLabel, pageTitle: typeof pageTitle !== 'undefined' ? pageTitle : 'Bảng điều khiển' }) %>
      
      <div class="app-content">
        <!-- Dashboard Overview -->
        <div id="view-dashboard" class="view-container active">
          <div class="project-grid" id="dashboard-summary">
            <!-- Dynamic stats/cards go here -->
            <div class="card section-card">
              <h3 class="section-title">Chào mừng trở lại!</h3>
              <p class="section-desc">Hệ thống quản lý tiến độ dự án tích hợp với Jira & GitHub.</p>
            </div>
          </div>
        </div>

        <!-- Project List View -->
        <div id="view-projects" class="view-container">
          <div class="section-head">
            <h2 class="section-title">Dự án của tôi</h2>
            <p class="section-desc">Danh sách các nhóm dự án bạn đang tham gia tham gia.</p>
          </div>
          <div class="project-grid" id="project-list-container">
            <!-- Loading projects... -->
            <p class="hint">Đang tải danh sách dự án...</p>
          </div>
        </div>

        <!-- Project Detail View -->
        <div id="view-project-detail" class="view-container">
          <!-- Back button or breadcrumbs could go here -->
          <div id="project-detail-content">
             <!-- Populated dynamically via JS -->
          </div>
          
          <div class="grid-layout" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem;">
            <div class="stack">
                <%- include('../sections/groups') %>
                <%- include('../sections/integration') %>
            </div>
            <div class="stack">
                <%- include('../sections/tasks') %>
                <%- include('../sections/reports') %>
            </div>
          </div>
        </div>

        <!-- Tasks View -->
        <div id="view-tasks" class="view-container">
           <%- include('../sections/tasks') %>
        </div>

        <!-- User Management View (ADMIN) -->
        <div id="view-users" class="view-container">
          <div class="section-head">
            <h2 class="section-title">Quản lý người dùng</h2>
            <p class="section-desc">Danh sách tất cả người dùng trong hệ thống.</p>
          </div>
          <div class="admin-grid" style="display: grid; grid-template-columns: 1fr; gap: 1.5rem;">
            <div class="card card-table-container">
              <table class="table" id="userListTable">
                <thead>
                  <tr>
                    <th>Họ tên</th>
                    <th>Username</th>
                    <th>Email</th>
                    <th>Vai trò</th>
                    <th>Hành động</th>
                  </tr>
                </thead>
                <tbody id="user-list-body">
                  <tr><td colspan="5" class="hint">Đang tải...</td></tr>
                </tbody>
              </table>
            </div>
            <%- include('../sections/admin-accounts') %>
          </div>
        </div>

        <!-- Create Project View (ADMIN/GIANG_VIEN) -->
        <div id="view-create-project" class="view-container">
          <div class="section-head">
            <h2 class="section-title">Khởi tạo Dự án mới</h2>
            <p class="section-desc">Tạo nhóm đồ án và gán chủ đề thực hiện.</p>
          </div>
          <div class="card" style="max-width: 600px;">
            <form id="standaloneCreateGroupForm" class="stack">
              <label class="field-label">Tên nhóm / Đồ án</label>
              <input name="tenNhom" class="input" placeholder="Ví dụ: Nhóm 1 - Web App" required />
              
              <label class="field-label">Đề tài thực hiện</label>
              <textarea name="deTai" class="input" rows="3" placeholder="Mô tả đề tài..." required></textarea>
              
              <button type="submit" class="btn btn-primary">🚀 Tạo dự án ngay</button>
            </form>
          </div>
        </div>

        <!-- Teams View (Admin/Teacher only) -->
        <div id="view-teams" class="view-container">
           <%- include('../sections/groups') %>
        </div>

        <!-- Reports View -->
        <div id="view-reports" class="view-container">
           <%- include('../sections/reports') %>
        </div>

        <!-- Legacy / API Output (Minimized) -->
        <hr style="margin-top: 2rem; border: none; border-top: 1px solid var(--border);" />
        <details>
          <summary style="cursor: pointer; color: var(--muted); font-size: 0.8rem;">Dữ liệu API thô</summary>
          <%- include('../sections/api-output') %>
        </details>
      </div>
    </div>
  </div>

  <script>
    window.APP_ROLE = "<%= _roleKey %>";
  </script>
  <script src="/js/dashboard.js"></script>
</body>
</html>
