<section class="card section-card" id="sec-groups">
  <div class="section-head" style="display: flex; justify-content: space-between; align-items: flex-start;">
    <div>
        <h2 class="section-title">Thành viên & Nhóm</h2>
        <p class="section-desc">Quản lý đội ngũ thực hiện dự án.</p>
    </div>
    <div class="btn-row" style="margin:0">
        <button class="btn btn-secondary btn-sm" onclick="document.getElementById('group-actions').toggleAttribute('hidden')">⚙️ Thao tác</button>
    </div>
  </div>

  <div id="group-actions" class="form-grid" hidden style="margin-bottom: 1.5rem; padding: 1rem; background: #f8fafc; border-radius: 8px;">
    <form id="createGroupForm" class="stack">
      <span class="form-legend">Tạo nhóm mới</span>
      <input name="tenNhom" class="input input-sm" placeholder="Tên nhóm" required />
      <input name="deTai" class="input input-sm" placeholder="Đề tài" required />
      <button type="submit" class="btn btn-primary btn-sm">Tạo</button>
    </form>

    <div class="stack" style="border-left: 2px solid var(--border); padding-left: 1rem;">
      <span class="form-legend">Tìm kiếm & Thêm thành viên</span>
      <div class="btn-row" style="margin:0; gap: 0.5rem;">
          <input type="text" id="userSearchInput" class="input input-sm" style="flex: 1" placeholder="Nhập tên, username hoặc email..." />
          <button type="button" id="userSearchBtn" class="btn btn-secondary btn-sm">🔍 Tìm</button>
      </div>
      <div id="search-results" class="stack" style="max-height: 150px; overflow-y: auto; background: white; border-radius: 4px; margin-top: 0.5rem; display: none;"></div>
      
      <form id="addMemberForm" class="stack" style="margin-top: 0.5rem;">
        <input type="hidden" name="groupId" />
        <input type="hidden" name="idSinhVien" id="selectedUserId" />
        <div id="selectedUserCard" class="hint" style="padding: 0.25rem 0.5rem; background: var(--border); border-radius: 4px; display: none;"></div>
        <select name="vaiTro" class="input input-sm">
          <option value="MEMBER">MEMBER</option>
          <option value="LEADER">LEADER</option>
        </select>
        <button type="submit" class="btn btn-primary btn-sm" id="addMemberBtn" disabled>Thêm vào nhóm</button>
      </form>
    </div>

    <form id="assignLecturerForm" class="stack">
      <span class="form-legend">Gán giảng viên</span>
      <input name="groupId" class="input input-sm" placeholder="UUID nhóm" />
      <input name="idGiangVien" class="input input-sm" placeholder="UUID giảng viên" />
      <button type="submit" class="btn btn-secondary btn-sm">Gán</button>
    </form>
  </div>

  <div id="members-container">
    <div class="project-grid" id="member-list" style="grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));">
        <!-- Dynamic list of members -->
        <p class="hint">Chọn một dự án để xem thành viên.</p>
    </div>
  </div>
</section>
