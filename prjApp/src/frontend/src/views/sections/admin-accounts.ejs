<section class="card section-card" id="sec-admin-accounts">
  <div class="section-head">
    <h2 class="section-title">Quản lý tài khoản</h2>
    <p class="section-desc">Tạo người dùng, phân quyền, xóa tài khoản (API <code>/api/users</code>).</p>
  </div>
  <div class="form-grid">
    <form id="createUserForm" class="stack">
      <span class="form-legend">Tạo tài khoản</span>
      <input name="username" class="input" placeholder="Tên đăng nhập" required autocomplete="off" />
      <input name="password" class="input" type="password" placeholder="Mật khẩu" required autocomplete="new-password" />
      <input name="hoTen" class="input" placeholder="Họ tên" required />
      <input name="email" class="input" type="email" placeholder="Email" required />
      <input name="maVaiTro" class="input input-mono" placeholder="QUAN_TRI_VIEN | GIANG_VIEN | SINH_VIEN | TRUONG_NHOM" required />
      <input name="maSo" class="input input-mono" placeholder="maSo: mã SV / mã GV / mã QTV (QTV có thể để trống)" />
      <input name="lop" class="input" placeholder="Lớp (sinh viên, tùy chọn)" />
      <input name="khoa" class="input" placeholder="Khoa (giảng viên, tùy chọn)" />
      <button type="submit" class="btn btn-primary">Tạo</button>
    </form>
    <form id="updateRoleForm" class="stack">
      <span class="form-legend">Đổi vai trò</span>
      <input name="userId" class="input input-mono" placeholder="UUID người dùng" required />
      <input name="role" class="input input-mono" placeholder="Mã vai trò" required />
      <button type="submit" class="btn btn-secondary">Cập nhật</button>
    </form>
    <form id="deleteUserForm" class="stack">
      <span class="form-legend">Xóa tài khoản</span>
      <input name="userId" class="input input-mono" placeholder="UUID người dùng" required />
      <button type="submit" class="btn btn-danger">Xóa</button>
    </form>
  </div>
</section>
