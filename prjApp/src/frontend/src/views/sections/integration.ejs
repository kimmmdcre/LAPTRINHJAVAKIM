<section class="card section-card" id="sec-integration">
  <div class="section-head">
    <h2 class="section-title">Tích hợp & đồng bộ</h2>
    <p class="section-desc">Cấu hình Jira/GitHub cho nhóm, đồng bộ dữ liệu và liên kết commit–task.</p>
  </div>
  <div class="form-grid">
    <form id="configJiraForm" class="stack">
      <span class="form-legend">Cấu hình Jira</span>
      <input name="idNhom" class="input input-mono" placeholder="UUID nhóm" required />
      <input name="url" class="input" placeholder="URL Jira" required />
      <input name="token" class="input input-mono" type="password" placeholder="Token" required />
      <button type="submit" class="btn btn-primary">Lưu Jira</button>
    </form>
    <form id="configGithubForm" class="stack">
      <span class="form-legend">Cấu hình GitHub</span>
      <input name="idNhom" class="input input-mono" placeholder="UUID nhóm" required />
      <input name="repo" class="input input-mono" placeholder="owner/repo" required />
      <input name="token" class="input input-mono" type="password" placeholder="Token" required />
      <input name="since" class="input input-mono" placeholder="2024-01-01T00:00:00Z (tùy chọn)" />
      <button type="submit" class="btn btn-primary">Lưu GitHub</button>
    </form>
    <form id="syncJiraForm" class="stack">
      <span class="form-legend">Đồng bộ Jira</span>
      <input name="idNhom" class="input input-mono" placeholder="UUID nhóm" required />
      <button type="submit" class="btn btn-secondary">Chạy sync</button>
    </form>
    <form id="syncGithubForm" class="stack">
      <span class="form-legend">Đồng bộ GitHub</span>
      <input name="idNhom" class="input input-mono" placeholder="UUID nhóm" required />
      <button type="submit" class="btn btn-secondary">Chạy sync</button>
    </form>
    <div class="stack" style="grid-column: 1 / -1; margin-top: 1rem; padding: 1.5rem; background: rgba(59, 130, 246, 0.05); border: 2px dashed var(--info); border-radius: 12px; text-align: center;">
      <span class="form-legend">Liên kết thông minh</span>
      <p class="section-desc" style="margin-bottom: 1rem;">Tự động Đồng bộ Jira → Đồng bộ GitHub → Khớp nối Commit với Task.</p>
      <button type="button" id="smartSyncBtn" class="btn btn-primary" style="padding: 0.75rem 2rem; font-size: 1rem;">
        🚀 Chạy Đồng bộ Toàn diện (Smart Sync)
      </button>
      <div id="sync-status" class="hint" style="margin-top: 0.75rem; font-weight: 600;"></div>
    </div>
  </div>
</section>
