<section class="card section-card" id="sec-reports">
  <div class="section-head">
    <h2 class="section-title">Báo cáo & Thống kê</h2>
    <p class="section-desc">Theo dõi tiến độ tổng thể, thống kê commit và đóng góp của từng thành viên.</p>
  </div>

  <div class="report-dashboard">
    <!-- Quick Stats -->
    <div class="stats-row" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; margin-bottom: 2rem;">
      <div class="card stat-card" style="background: var(--primary); color: white;">
        <span class="stat-label">Tổng nhiệm vụ</span>
        <strong class="stat-value" id="stat-tasks-total">0</strong>
      </div>
      <div class="card stat-card">
        <span class="stat-label">Đã hoàn thành</span>
        <strong class="stat-value" id="stat-tasks-done" style="color: var(--success)">0</strong>
      </div>
      <div class="card stat-card">
        <span class="stat-label">Tổng commit</span>
        <strong class="stat-value" id="stat-commits-total">0</strong>
      </div>
    </div>

    <!-- Charts / Lists -->
    <div class="grid-layout" style="display: grid; grid-template-columns: 1.5fr 1fr; gap: 1.5rem;">
      <div class="card">
        <h3 class="section-title" style="font-size: 1rem;">Biểu đồ đóng góp (Commits)</h3>
        <div id="contribution-chart" class="stack" style="margin-top: 1rem;">
           <!-- Dynamic bars go here -->
           <p class="hint">Chọn một dự án để xem dữ liệu.</p>
        </div>
      </div>
      
      <div class="card stack">
        <h3 class="section-title" style="font-size: 1rem;">Xuất dữ liệu</h3>
        <div class="btn-row" style="flex-wrap: wrap;">
          <button class="btn btn-secondary btn-sm" onclick="alert('Tính năng xuất CSV đang được khởi tạo...')">📥 Xuất CSV (Bảng điểm)</button>
          <button class="btn btn-secondary btn-sm" onclick="alert('Tính năng xuất PDF đang được khởi tạo...')">📄 Xuất báo cáo PDF</button>
        </div>
        <p class="hint" style="margin-top: 0.5rem;">Dữ liệu sẽ được tổng hợp từ Jira (Tasks) và GitHub (Commits).</p>
      </div>
    </div>
  </div>
</section>
